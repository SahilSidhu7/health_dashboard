{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "health-dashboard",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "entry": "index.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "Health Dashboard",
        "description": "Open Community Health Dashboard",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/health-dashboard"
      }
    ]
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "permissions": {
    "reddit": true
  },
  "dev": {
    "subreddit": "health_dashboard_dev"
  }
}